DISCORD_BOT_TOKEN=

# Webshare residential-proxy URL for the host-side cf-fetch-server sidecar.
# Format: http://<user>:<pass>@<host>:<port>
# - Lives ONLY on the host (this file + ~/Library/LaunchAgents/com.nanoclaw.cf-fetch-server.plist).
# - NEVER injected into the container or container env.
# - host-helpers/cf-fetch-server/install.sh reads this line at install time
#   and writes it into the launchd plist's EnvironmentVariables so the
#   sidecar process picks it up at startup. The webshare endpoint rotates
#   exit IPs per TCP connection, so each /fetch call (new tab) gets a
#   fresh IP without restarting the warm browser.
# Leave unset to run cf-fetch-server without proxy (CF bypass disabled).
HTTP_PROXY_URL=
